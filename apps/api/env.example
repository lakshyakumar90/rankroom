DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
REDIS_URL=redis://localhost:6379
JUDGE0_URL=http://localhost:2358
# Deprecated alias (still supported): JUDGE0_API_URL=http://localhost:2358
JUDGE0_API_KEY=
# Single-request timeout (ms). TypeScript compile+run can be slow; 30s is safer than 15s.
JUDGE0_TIMEOUT_MS=30000
# Extra attempts after the first call when Judge0 returns 5xx (503 overload) or the connection drops.
JUDGE0_REQUEST_RETRIES=5
# Judge0 request-level defaults and safety caps (can be lower than per-language computed limits).
JUDGE0_CPU_TIME_LIMIT=10
JUDGE0_WALL_TIME_LIMIT=20
JUDGE0_MEMORY_LIMIT=900000
JUDGE0_MAX_CPU_TIME_LIMIT=20
JUDGE0_MAX_WALL_TIME_LIMIT=20
JUDGE0_MAX_MEMORY_LIMIT=2097152
WORKER_CONCURRENCY=4
JUDGE0_RATE_LIMIT_PER_SEC=25
JUDGE0_RATE_LIMIT_BURST=50
TS_EXECUTION_MODE=transpile
MAX_SOURCE_CODE_BYTES=65536
MAX_STDIN_BYTES=32768
MAX_OUTPUT_BYTES=16384
MAX_TEST_CASES_PER_RUN=50
MAX_TEST_CASES_PER_SUBMIT=100
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
OPENROUTER_FALLBACK_MODELS=meta-llama/llama-3.3-70b-instruct:free,google/gemini-flash-1.5
OPENROUTER_TIMEOUT_MS=20000
OPENROUTER_MAX_ATTEMPTS=2
OPENROUTER_REFERER=https://rankroom.app
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_MS=15000
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
