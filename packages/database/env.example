# Postgres (Prisma migrate / seed data)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase Auth — required for `pnpm db:seed` to create login users (Project Settings → API)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Optional: single password for all seeded accounts (default: RankRoomSeed#2026)
# SEED_USER_PASSWORD=
