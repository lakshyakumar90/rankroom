generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                            String                          @id @default(cuid())
  supabaseId                    String                          @unique
  email                         String                          @unique
  name                          String
  role                          Role                            @default(STUDENT)
  avatar                        String?
  isVerified                    Boolean                         @default(false)
  isActive                      Boolean                         @default(true)
  deactivatedAt                 DateTime?
  deactivatedById               String?
  deactivationReason            String?
  githubUsername                String?
  createdAt                     DateTime                        @default(now())
  updatedAt                     DateTime                        @updatedAt
  activityLogs                  ActivityLog[]
  assignmentAudience            AssignmentAudience[]
  assignmentSubmissions         AssignmentSubmission[]
  assignmentsCreated            Assignment[]                    @relation("AssignmentCreator")
  attendanceRecords             AttendanceRecord[]
  attendanceTaken               AttendanceSession[]             @relation("AttendanceTaker")
  certificatesApproved          Certificate[]                   @relation("CertificateApprover")
  certificatesEarned            Certificate[]                   @relation("StudentCertificates")
  competitionRegistrations      CompetitionRegistration[]       @relation("CompetitionParticipant")
  competitionsCreated           Competition[]                   @relation("CompetitionCreator")
  contestAudience               ContestAudience[]
  contestRegistrations          ContestRegistration[]
  contestStandings              ContestStanding[]
  contestsCreated               Contest[]                       @relation("ContestCreator")
  departmentHeaded               Department?                     @relation("DepartmentHead")
  enrollments                   Enrollment[]
  gradesReceived                Grade[]                         @relation("StudentGrades")
  gradesGiven                   Grade[]                         @relation("TeacherGrades")
  hackathonAudience             HackathonAudience[]
  hackathonRegistrations        HackathonRegistration[]         @relation("HackathonParticipant")
  hackathonStandings            HackathonStanding[]
  hackathonTeamsLed             HackathonTeam[]                 @relation("HackathonTeamLeader")
  hackathonsCreated             Hackathon[]                     @relation("HackathonCreator")
  hackathonWinnerEntriesAdded   HackathonWinnerEntry[]
  leaderboard                   Leaderboard?
  notifications                 Notification[]
  problemsApproved              Problem[]                       @relation("ProblemApprover")
  problemsCreated               Problem[]                       @relation("ProblemCreator")
  profile                       Profile?
  sectionLeaderboardEntries     SectionLeaderboard[]            @relation("SectionLeaderboardStudent")
  // Legacy: one user may be listed as primary coordinator on many sections
  coordinatedSections           Section[]                       @relation("SectionCC")
  legacyTeachingSections        Section[]                       @relation("SectionLegacyTeacher")
  studentProfile                StudentProfile?
  submissions                   Submission[]
  teachingAssignments           TeacherSubjectAssignment[]      @relation("TeacherAssignments")
  // New M:N coordinator assignments
  sectionCoordinatorAssignments SectionCoordinatorAssignment[]  @relation("CoordinatorAssignments")
  sectionCoordinatorAssigned    SectionCoordinatorAssignment[]  @relation("CoordinatorAssignedBy")
  // Settings
  settings                      UserSettings?
  // Subject audit
  subjectAuditLogs              SubjectAuditLog[]               @relation("SubjectAuditActor")
  // Event teams
  eventTeamsLed                 EventTeam[]                     @relation("EventTeamLeader")
  eventTeamMemberships          EventTeamMember[]               @relation("EventTeamMemberships")
  eventTeamJoinRequests         EventTeamJoinRequest[]          @relation("EventTeamJoinRequests")
  eventTeamJoinRequestsResponded EventTeamJoinRequest[]         @relation("EventTeamJoinRequestResponder")
  eventTeamInvitesReceived      EventTeamInvite[]               @relation("EventTeamInvitesReceived")
  eventTeamInvitesSent          EventTeamInvite[]               @relation("EventTeamInvitesSent")
  coachAdvice                   CoachAdvice[]
  skillSnapshots                UserSkillSnapshot[]
  skillProfile                  UserSkillProfile?

  @@map("users")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  bio         String?
  phoneNumber String?
  skills      String[]
  socialLinks Json?
  college     String?
  batch       String?
  department  String?
  totalPoints Int      @default(0)
  rank        Int?
  streak      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  handle      String?  @unique
  isPublic    Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model StudentProfile {
  id                     String        @id @default(cuid())
  userId                 String        @unique
  phoneNumber            String?
  leetcodeUsername       String?
  githubUsername         String?
  codechefUsername       String?
  codeforcesUsername     String?
  hackerrankUsername     String?
  leetcodeSolved         Int           @default(0)
  leetcodeEasy           Int           @default(0)
  leetcodeMedium         Int           @default(0)
  leetcodeHard           Int           @default(0)
  leetcodeAcceptanceRate Float?
  githubContributions    Int           @default(0)
  githubTopLanguages     Json          @default("[]")
  codechefRating         Int?
  codechefMaxRating      Int?
  codechefStars          Int?
  codeforcesRating       Int?
  codeforcesMaxRating    Int?
  codeforcesRank         String?
  cgpa                   Float?
  activityHeatmap        Json          @default("{}")
  currentStreak          Int           @default(0)
  longestStreak          Int           @default(0)
  lastActiveDate         DateTime?     @db.Date
  lastSyncedAt           DateTime?
  bio                    String?
  resumeUrl              String?
  resumeFilename         String?
  avatarPath             String?
  isPublic               Boolean       @default(true)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  achievements           Achievement[]
  projects               Project[]
  skills                 Skill[]
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_profiles")
}

model Skill {
  id        String         @id @default(cuid())
  name      String
  category  String
  level     SkillLevel     @default(BEGINNER)
  profileId String
  profile   StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([name, profileId])
  @@map("skills")
}

model Project {
  id          String         @id @default(cuid())
  title       String
  description String
  techStack   String[]
  githubUrl   String?
  liveUrl     String?
  imageUrl    String?
  featured    Boolean        @default(false)
  profileId   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  profile     StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model Achievement {
  id             String         @id @default(cuid())
  title          String
  description    String?
  date           DateTime
  category       String
  certificateUrl String?
  profileId      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  profile        StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("achievements")
}

model Department {
  id                    String         @id @default(cuid())
  name                  String
  code                  String         @unique
  headId                String?        @unique
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  description           String?
  competitions          Competition[]
  contests              Contest[]      @relation("ContestDepartment")
  head                  User?          @relation("DepartmentHead", fields: [headId], references: [id])
  hackathons            Hackathon[]
  problems              Problem[]      @relation("ProblemDepartment")
  targetedNotifications Notification[] @relation("NotificationTargetDepartment")
  sections              Section[]
  subjects              Subject[]

  @@map("departments")
}

model Section {
  id                    String                          @id @default(cuid())
  name                  String
  legacyYear            Int?                            @map("year")
  semester              Int
  departmentId          String
  legacyTeacherId       String?                         @map("teacherId")
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt
  code                  String
  academicYear          String
  // Legacy single-coordinator (kept for backward compat; @unique removed to unblock M:N)
  coordinatorId         String?
  attendanceSessions    AttendanceSession[]
  competitions          Competition[]
  contests              Contest[]
  enrollments           Enrollment[]
  problems              Problem[]                       @relation("ProblemClass")
  targetedNotifications Notification[]                  @relation("NotificationTargetSection")
  leaderboardEntries    SectionLeaderboard[]
  coordinator           User?                           @relation("SectionCC", fields: [coordinatorId], references: [id])
  department            Department                      @relation(fields: [departmentId], references: [id])
  legacyTeacher         User?                           @relation("SectionLegacyTeacher", fields: [legacyTeacherId], references: [id])
  subjects              Subject[]
  teacherAssignments    TeacherSubjectAssignment[]
  // M:N coordinator assignments (new canonical store)
  coordinatorAssignments SectionCoordinatorAssignment[]

  @@unique([code, departmentId, academicYear])
  @@map("sections")
}

model Enrollment {
  id         String   @id @default(cuid())
  studentId  String
  sectionId  String
  enrolledAt DateTime @default(now())
  section    Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, sectionId])
  @@map("enrollments")
}

model Subject {
  id                 String                     @id @default(cuid())
  name               String
  code               String
  sectionId          String
  departmentId       String
  teacherId          String?
  minimumAttendancePct Float                    @default(75)
  lateAttendanceWeight Float                    @default(0.5)
  isArchived         Boolean                    @default(false)
  archivedAt         DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  assignments        Assignment[]
  attendanceSessions AttendanceSession[]
  contests           Contest[]                  @relation("ContestSubject")
  grades             Grade[]
  problems           Problem[]                  @relation("ProblemSubject")
  department         Department                 @relation(fields: [departmentId], references: [id])
  section            Section                    @relation(fields: [sectionId], references: [id])
  teacherAssignments TeacherSubjectAssignment[]
  resultConfig       SubjectResultConfig?
  auditLogs          SubjectAuditLog[]

  @@unique([code, sectionId])
  @@map("subjects")
}

model TeacherSubjectAssignment {
  id        String   @id @default(cuid())
  teacherId String
  subjectId String
  sectionId String
  createdAt DateTime @default(now())
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher   User     @relation("TeacherAssignments", fields: [teacherId], references: [id])

  @@unique([teacherId, subjectId, sectionId])
  @@map("teacher_subject_assignments")
}

model AttendanceSession {
  id        String             @id @default(cuid())
  date      DateTime           @db.Date
  sectionId String
  subjectId String
  takenById String
  createdAt DateTime           @default(now())
  topic     String?
  records   AttendanceRecord[]
  section   Section            @relation(fields: [sectionId], references: [id])
  subject   Subject            @relation(fields: [subjectId], references: [id])
  takenBy   User               @relation("AttendanceTaker", fields: [takenById], references: [id])

  @@unique([sectionId, subjectId, date])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id                  String            @id @default(cuid())
  attendanceSessionId String
  studentId           String
  status              AttendanceStatus  @default(PRESENT)
  excuseStatus        AttendanceExcuseStatus?
  excuseReason        String?
  excuseSubmittedAt   DateTime?
  excuseReviewedAt    DateTime?
  excuseReviewedById  String?
  attendanceSession   AttendanceSession @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)
  student             User              @relation(fields: [studentId], references: [id])

  @@unique([attendanceSessionId, studentId])
  @@map("attendance_records")
}

model Grade {
  id        String   @id @default(cuid())
  studentId String
  subjectId String
  teacherId String
  examType  ExamType
  marks     Float
  maxMarks  Float
  semester  Int
  remarks   String?
  isPublished Boolean @default(false)
  publishedAt DateTime?
  publishedById String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   User     @relation("StudentGrades", fields: [studentId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacher   User     @relation("TeacherGrades", fields: [teacherId], references: [id])

  @@map("grades")
}

model Assignment {
  id            String                 @id @default(cuid())
  title         String
  description   String
  subjectId     String
  teacherId     String
  dueDate       DateTime
  maxScore      Float
  attachmentUrl String?
  rubric        Json                   @default("[]")
  type          AssignmentType         @default(FILE_UPLOAD)
  status        AssignmentStatus       @default(CREATED)
  allowLate     Boolean                @default(false)
  latePenaltyPct Int                   @default(20)
  xpWeight      Int                    @default(15)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  audience      AssignmentAudience[]
  problems      AssignmentProblem[]
  questions     AssignmentQuestion[]
  submissions   AssignmentSubmission[]
  extensions    AssignmentExtension[]
  subject       Subject                @relation(fields: [subjectId], references: [id])
  teacher       User                   @relation("AssignmentCreator", fields: [teacherId], references: [id])

  @@map("assignments")
}

model AssignmentProblem {
  assignmentId String
  problemId    String
  order        Int        @default(0)
  points       Int        @default(100)
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  problem      Problem    @relation(fields: [problemId], references: [id])

  @@id([assignmentId, problemId])
  @@map("assignment_problems")
}

model AssignmentQuestion {
  id           String     @id @default(cuid())
  assignmentId String
  question     String
  options      Json
  correctAnswer String
  points       Int        @default(10)
  order        Int        @default(0)
  createdAt    DateTime   @default(now())
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@map("assignment_questions")
}

model AssignmentAudience {
  assignmentId String
  studentId    String
  createdAt    DateTime   @default(now())
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([assignmentId, studentId])
  @@map("assignment_audience")
}

model AssignmentSubmission {
  id              String                     @id @default(cuid())
  assignmentId    String
  studentId       String
  submittedAt     DateTime?
  fileUrl         String?
  content         String?
  score           Float?
  feedback        String?
  isLate          Boolean                    @default(false)
  codeSubmissions Json?
  mcqAnswers      Json?
  rubricEvaluation Json?
  gradedById      String?
  gradedAt        DateTime?
  publishedAt     DateTime?
  status          AssignmentSubmissionStatus @default(PENDING)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  assignment      Assignment                 @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student         User                       @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@map("assignment_submissions")
}

model AssignmentExtension {
  id             String     @id @default(cuid())
  assignmentId   String
  studentId      String
  extendedDueDate DateTime
  reason         String?
  grantedById    String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  assignment     Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@map("assignment_extensions")
}

model Problem {
  id             String              @id @default(cuid())
  title          String
  slug           String              @unique
  description    String
  difficulty     Difficulty
  tags           String[]
  scope          ProblemScope        @default(GLOBAL)
  scopeSectionId String?
  scopeDepartmentId String?
  constraints    String?
  inputFormat    String?
  outputFormat   String?
  sampleInput    String?
  sampleOutput   String?
  functionName   String?
  parameterNames String[]            @default([])
  parameterTypes Json?
  returnType     String?
  starterCode    Json?
  compareMode    CompareMode         @default(IGNORE_TRAILING_WHITESPACE)
  timeLimitMs    Int                 @default(2000)
  memoryLimitKb  Int                 @default(262144)
  acceptedSubmissions Int            @default(0)
  totalSubmissions Int               @default(0)
  createdById    String
  isPublished    Boolean             @default(false)
  points         Int
  visibility     ProblemVisibility   @default(GLOBAL)
  approvalStatus ApprovalStatus      @default(APPROVED)
  approvedById   String?
  classId        String?
  departmentId   String?
  subjectId      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  assignments    AssignmentProblem[]
  contests       ContestProblem[]
  hackathons     HackathonProblem[]
  approvedBy     User?               @relation("ProblemApprover", fields: [approvedById], references: [id])
  class          Section?            @relation("ProblemClass", fields: [classId], references: [id])
  department     Department?         @relation("ProblemDepartment", fields: [departmentId], references: [id])
  createdBy      User                @relation("ProblemCreator", fields: [createdById], references: [id])
  subject        Subject?            @relation("ProblemSubject", fields: [subjectId], references: [id])
  boilerplates   Boilerplate[]
  hints          Hint[]
  editorial      Editorial?
  problemTags    ProblemTag[]
  submissions    Submission[]
  testCases      TestCase[]

  @@map("problems")
}

model TestCase {
  id             String   @id @default(cuid())
  problemId      String
  input          String
  expectedOutput String
  isSample       Boolean  @default(false)
  isHidden       Boolean  @default(false)
  createdAt      DateTime @default(now())
  problem        Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("test_cases")
}

model Boilerplate {
  id        String   @id @default(cuid())
  problemId String
  language  String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, language])
  @@map("problem_boilerplates")
}

model Hint {
  id        String   @id @default(cuid())
  problemId String
  tier      Int      @default(1)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, tier])
  @@map("problem_hints")
}

model Editorial {
  id            String   @id @default(cuid())
  problemId     String   @unique
  summary       String?
  approach      String?
  complexity    String?
  fullEditorial String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  problem       Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("problem_editorials")
}

model Tag {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  problems  ProblemTag[]

  @@map("tags")
}

model ProblemTag {
  problemId  String
  tagId      String
  createdAt  DateTime @default(now())
  problem    Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([problemId, tagId])
  @@map("problem_tags")
}

model Submission {
  id          String           @id @default(cuid())
  userId      String
  problemId   String
  contestId   String?
  hackathonId String?
  code        String
  language    String
  status      SubmissionStatus @default(PENDING)
  runtime     Int?
  memory      Int?
  verdict     Json?
  testResults Json?
  compileError String?
  stderr      String?
  createdAt   DateTime         @default(now())
  contest     Contest?         @relation(fields: [contestId], references: [id])
  problem     Problem          @relation(fields: [problemId], references: [id])
  user        User             @relation(fields: [userId], references: [id])

  @@map("submissions")
}

model Contest {
  id              String                @id @default(cuid())
  title           String
  description     String
  startTime       DateTime
  endTime         DateTime
  registrationEnd DateTime?
  freezeTime      DateTime?
  type            ContestType           @default(PUBLIC)
  scope           ContestScope          @default(GLOBAL)
  status          ContestStatus         @default(UPCOMING)
  createdById     String
  rules           String?
  penaltyMinutes  Int                   @default(10)
  allowLateJoin   Boolean               @default(false)
  aiDisabled      Boolean               @default(true)
  xpReward        Int                   @default(100)
  maxParticipants Int?
  departmentId    String?
  subjectId       String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  sectionId       String?
  audience        ContestAudience[]
  problems        ContestProblem[]
  registrations   ContestRegistration[]
  standings       ContestStanding[]
  createdBy       User                  @relation("ContestCreator", fields: [createdById], references: [id])
  department      Department?           @relation("ContestDepartment", fields: [departmentId], references: [id])
  section         Section?              @relation(fields: [sectionId], references: [id])
  subject         Subject?              @relation("ContestSubject", fields: [subjectId], references: [id])
  submissions     Submission[]

  @@map("contests")
}

model ContestProblem {
  contestId String
  problemId String
  order     Int     @default(0)
  points    Int     @default(100)
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem   Problem @relation(fields: [problemId], references: [id])

  @@id([contestId, problemId])
  @@map("contest_problems")
}

model ContestRegistration {
  contestId       String
  userId          String
  registeredAt    DateTime           @default(now())
  status          RegistrationStatus @default(REGISTERED)
  eligibilityNote String?
  registeredById  String?
  contest         Contest            @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id])

  @@id([contestId, userId])
  @@map("contest_registrations")
}

model ContestAudience {
  contestId String
  studentId String
  createdAt DateTime @default(now())
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([contestId, studentId])
  @@map("contest_audience")
}

model ContestStanding {
  id             String    @id @default(cuid())
  contestId      String
  userId         String
  totalScore     Int       @default(0)
  penalty        Int       @default(0)
  rank           Int?
  solvedCount    Int       @default(0)
  acceptedCount  Int       @default(0)
  wrongCount     Int       @default(0)
  solveTimeSeconds Int     @default(0)
  perProblemResults Json   @default("{}")
  lastAcceptedTime DateTime?
  lastSubmitTime DateTime?
  updatedAt      DateTime  @updatedAt
  contest        Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id])

  @@unique([contestId, userId])
  @@map("contest_standings")
}

model Leaderboard {
  id                   String   @id @default(cuid())
  userId               String   @unique
  totalPoints          Int      @default(0)
  problemsSolved       Int      @default(0)
  easySolved           Int      @default(0)
  mediumSolved         Int      @default(0)
  hardSolved           Int      @default(0)
  contestsParticipated Int      @default(0)
  rank                 Int?
  weeklyRank           Int?
  monthlyRank          Int?
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("leaderboard")
}

model Hackathon {
  id                   String                  @id @default(cuid())
  title                String
  description          String
  departmentId         String?
  createdById          String
  type                 HackathonType           @default(DSA)
  minSkills            String[]
  minProjects          Int                     @default(0)
  minLeetcode          Int                     @default(0)
  minCgpa              Float?
  eligibility          Json?
  xpRewards            Json?
  startDate            DateTime
  endDate              DateTime
  freezeTime           DateTime?
  registrationDeadline DateTime
  maxTeamSize          Int                     @default(4)
  minTeamSize          Int                     @default(1)
  prizeDetails         String?
  status               HackathonStatus         @default(UPCOMING)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  audience             HackathonAudience[]
  problems             HackathonProblem[]
  registrations        HackathonRegistration[]
  standings            HackathonStanding[]
  teams                HackathonTeam[]
  winnerEntries        HackathonWinnerEntry[]
  createdBy            User                    @relation("HackathonCreator", fields: [createdById], references: [id])
  department           Department?             @relation(fields: [departmentId], references: [id])

  @@map("hackathons")
}

model HackathonProblem {
  hackathonId String
  problemId   String
  order       Int       @default(0)
  points      Int       @default(100)
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  problem     Problem   @relation(fields: [problemId], references: [id])

  @@id([hackathonId, problemId])
  @@map("hackathon_problems")
}

model HackathonStanding {
