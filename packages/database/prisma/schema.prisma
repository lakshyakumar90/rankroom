model Certificate {
  id               String          @id @default(cuid())
  studentId        String
  type             CertificateType
  title            String
  description      String?
  issuedAt         DateTime        @default(now())
  externalUrl      String?
  proofFile        String?
  status           CertStatus      @default(PENDING)
  approvedById     String?
  approvedAt       DateTime?
  rejectionReason  String?
  xpBonus          Int             @default(0)
  verificationCode String?         @unique
  certificateUrl   String?
  contestId        String?
  hackathonId      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  approvedBy       User?           @relation("CertificateApprover", fields: [approvedById], references: [id])
  student          User            @relation("StudentCertificates", fields: [studentId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

model Competition {
  id            String                    @id @default(cuid())
  title         String
  description   String
  departmentId  String?
  sectionId     String?
  createdById   String
  type          CompetitionType
  minSkills     String[]
  minProjects   Int                       @default(0)
  startDate     DateTime
  endDate       DateTime
  status        HackathonStatus           @default(UPCOMING)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  registrations CompetitionRegistration[]
  createdBy     User                      @relation("CompetitionCreator", fields: [createdById], references: [id])
  department    Department?               @relation(fields: [departmentId], references: [id])
  section       Section?                  @relation(fields: [sectionId], references: [id])

  @@map("competitions")
}

model CompetitionRegistration {
  id            String      @id @default(cuid())
  competitionId String
  studentId     String
  isEligible    Boolean     @default(false)
  registeredAt  DateTime    @default(now())
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  student       User        @relation("CompetitionParticipant", fields: [studentId], references: [id])

  @@unique([competitionId, studentId])
  @@map("competition_registrations")
}

model SectionLeaderboard {
  id              String   @id @default(cuid())
  sectionId       String
  studentId       String
  cgpaScore       Float    @default(0)
  codingScore     Float    @default(0)
  assignmentScore Float    @default(0)
  hackathonScore  Float    @default(0)
  profileScore    Float    @default(0)
  externalScore   Float    @default(0)
  totalScore      Float    @default(0)
  rank            Int?
  lastComputedAt  DateTime @default(now())
  updatedAt       DateTime @updatedAt
  section         Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  student         User     @relation("SectionLeaderboardStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sectionId, studentId])
  @@map("section_leaderboard")
}

model Notification {
  id                 String           @id @default(cuid())
  userId             String
  type               NotificationType
  title              String
  message            String
  isRead             Boolean          @default(false)
  link               String?
  createdAt          DateTime         @default(now())
  entityId           String?
  entityType         String?
  targetDepartmentId String?
  targetRole         Role?
  targetSectionId    String?
  // Idempotency key to prevent duplicate reminder notifications
  dedupeKey          String?
  targetDepartment   Department?      @relation("NotificationTargetDepartment", fields: [targetDepartmentId], references: [id])
  targetSection      Section?         @relation("NotificationTargetSection", fields: [targetSectionId], references: [id])
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dedupeKey])
  @@map("notifications")
}

model UserSkillProfile {
