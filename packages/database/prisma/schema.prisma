/// M:N table replacing the single Section.coordinatorId
model SectionCoordinatorAssignment {
  id           String   @id @default(cuid())
  userId       String
  sectionId    String
  assignedAt   DateTime @default(now())
  assignedById String?
  isActive     Boolean  @default(true)
  user         User     @relation("CoordinatorAssignments", fields: [userId], references: [id], onDelete: Cascade)
  section      Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  assignedBy   User?    @relation("CoordinatorAssignedBy", fields: [assignedById], references: [id])

  @@unique([userId, sectionId])
  @@map("section_coordinator_assignments")
}

/// Role-aware user preferences and notification settings
model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  notificationsEnabled Boolean  @default(true)
  emailDigest          Boolean  @default(false)
  contestReminders     Boolean  @default(true)
  hackathonReminders   Boolean  @default(true)
  assignmentReminders  Boolean  @default(true)
  attendanceAlerts     Boolean  @default(true)
  theme                String?
  publicProfileDefault Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

/// Per-subject grading component configuration for marks validation
model SubjectResultConfig {
  id            String   @id @default(cuid())
  subjectId     String   @unique
  maxMidTerm    Float    @default(25)
  maxEndTerm    Float    @default(50)
  maxAssignment Float    @default(15)
  maxTC         Float    @default(10)
  credits       Int?
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@map("subject_result_configs")
}

/// Audit trail for subject name/teacher/archive changes
model SubjectAuditLog {
  id        String   @id @default(cuid())
  subjectId String
  actorId   String
  action    String
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())
  actor     User     @relation("SubjectAuditActor", fields: [actorId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@map("subject_audit_logs")
}

/// Unified event team for hackathons and team contests
model EventTeam {
  id            String                 @id @default(cuid())
  hackathonId   String?
  contestId     String?
  name          String
  teamCode      String                 @unique
  leaderId      String
  submissionUrl String?
  isLocked      Boolean                @default(false)
  lockedAt      DateTime?
  rank          Int?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  leader        User                   @relation("EventTeamLeader", fields: [leaderId], references: [id])
  members       EventTeamMember[]
  joinRequests  EventTeamJoinRequest[]
  invites       EventTeamInvite[]

  @@map("event_teams")
}

/// Approved member of an event team
model EventTeamMember {
  id       String    @id @default(cuid())
  teamId   String
  userId   String
  isLeader Boolean   @default(false)
  joinedAt DateTime  @default(now())
  team     EventTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User      @relation("EventTeamMemberships", fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@map("event_team_members")
}

/// Pending join request from a student to a team
model EventTeamJoinRequest {
  id          String            @id @default(cuid())
  teamId      String
  userId      String
  status      TeamRequestStatus @default(PENDING)
  message     String?
  respondedAt DateTime?
  respondedBy String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  team        EventTeam         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user        User              @relation("EventTeamJoinRequests", fields: [userId], references: [id])
  responder   User?             @relation("EventTeamJoinRequestResponder", fields: [respondedBy], references: [id])

  @@unique([teamId, userId])
  @@map("event_team_join_requests")
}

/// Invitation sent by a team leader to a student
model EventTeamInvite {
  id          String            @id @default(cuid())
  teamId      String
  invitedId   String
  invitedById String
  status      TeamRequestStatus @default(PENDING)
  expiresAt   DateTime?
  respondedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  team        EventTeam         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invited     User              @relation("EventTeamInvitesReceived", fields: [invitedId], references: [id])
  invitedBy   User              @relation("EventTeamInvitesSent", fields: [invitedById], references: [id])

  @@unique([teamId, invitedId])
  @@map("event_team_invites")
}

/// Queue table for scheduled reminder notifications
model ScheduledNotification {
  id             String                      @id @default(cuid())
  jobType        String
  entityType     String
  entityId       String
  scheduledFor   DateTime
  recipientScope Json
  status         ScheduledNotificationStatus @default(PENDING)
  processedAt    DateTime?
  failedAt       DateTime?
  lastError      String?
  attemptCount   Int                         @default(0)
  dedupeKey      String                      @unique
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@index([status, scheduledFor])
  @@map("scheduled_notifications")
}

/// Audit log for each reminder job run
model ReminderJobRun {
  id             String   @id @default(cuid())
  jobType        String
  ranAt          DateTime @default(now())
  candidateCount Int      @default(0)
  deliveredCount Int      @default(0)
  failedCount    Int      @default(0)
  durationMs     Int?
  error          String?
  metadata       Json?

  @@map("reminder_job_runs")
}

